{
  "name": "backbone",
  "description": "Give your JS App some Backbone with Models, Views, Collections, and Events.",
  "type": "module",
  "url": "http://backbonejs.org",
  "keywords": [
    "model",
    "view",
    "controller",
    "router",
    "server",
    "client",
    "browser"
  ],
  "author": "Olkhovoy Dmitry",
  "dependencies": {},
  "devDependencies": {
    "cpy-cli": "^5.0.0",
    "docco": "^0.9.1",
    "eslint": "^8.7.0",
    "eslint-plugin-import": "^2.28.1",
    "replace-in-file": "^7.0.1",
    "terser": "^5.31.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "jsdom": "^24.1.0"
  },
  "scripts": {
    "build": "tsc && terser dist/backbone.js -o dist/backbone-min.js --source-map",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/*.ts",
    "doc": "docco backbone.js && docco examples/todos/todos.js examples/backbone.localStorage.js",
    "mark-release": "replace-in-file MARK_DEVELOPMENT MARK_RELEASE modules/debug-info.js",
    "mark-develop": "replace-in-file MARK_RELEASE MARK_DEVELOPMENT modules/debug-info.js",
    "prepublishOnly": "npm run test && npm run build"
  },
  "main": "dist/backbone.js",
  "module": "dist/backbone.js",
  "types": "dist/backbone.d.ts",
  "version": "1.6.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jashkenas/backbone.git"
  },
  "files": [
    "dist/",
    "LICENSE"
  ]
}
