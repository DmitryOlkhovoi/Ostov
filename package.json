{
  "name": "ostovjs",
  "description": "Give your JS App some Ostov with Models, Views, Collections, and Events.",
  "type": "module",
  "homepage": "https://ostovjs.org",
  "keywords": [
    "model",
    "view",
    "controller",
    "router",
    "server",
    "client",
    "browser"
  ],
  "author": "Olkhovoy Dmitry",
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "cpy-cli": "^5.0.0",
    "docco": "^0.9.1",
    "eslint": "^8.7.0",
    "eslint-plugin-import": "^2.28.1",
    "jsdom": "^24.1.0",
    "replace-in-file": "^7.0.1",
    "rollup": "^4.59.0",
    "terser": "^5.31.0",
    "tslib": "^2.8.1",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "scripts": {
    "build": "rollup -c",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/*.ts",
    "doc": "npm run build && docco dist/ostov.js && sed -i '' 's|href=\"../docco.css\"|href=\"docco.css\"|' docs/dist/ostov.html && mv docs/dist/ostov.html docs/ostov.html && rm -rf docs/dist && docco examples/todos/todos.js examples/ostov.localStorage.js",
    "mark-release": "replace-in-file MARK_DEVELOPMENT MARK_RELEASE modules/debug-info.js",
    "mark-develop": "replace-in-file MARK_RELEASE MARK_DEVELOPMENT modules/debug-info.js",
    "prepublishOnly": "npm run test && npm run build"
  },
  "main": "dist/ostov.js",
  "module": "dist/ostov.js",
  "types": "dist/ostov.d.ts",
  "exports": {
    ".": {
      "import": "./dist/ostov.js",
      "types": "./dist/ostov.d.ts"
    }
  },
  "version": "1.7.6",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DmitryOlkhovoi/Ostov.git"
  },
  "files": [
    "dist/",
    "LICENSE"
  ]
}
